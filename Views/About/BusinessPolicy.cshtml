    <div class="section__breadcrumb">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">หน้าแรก</a></li>

                <li class="breadcrumb-item dropdown">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        เกี่ยวกับเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">รู้จักเรา</a></li>
                        <li><a class="dropdown-item" href="#">การจัดการองค์กร</a></li>
                        <li><a class="dropdown-item" href="#">นโยบายดำเนินการ</a></li>
                    </ul>
                </li>

                <li class="breadcrumb-item dropdown active" aria-current="page">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        รู้จักเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">วิสัยทัศน์ / พันธกิจ</a></li>
                        <li><a class="dropdown-item" href="#">ประวัติความเป็นมา</a></li>
                    </ul>
                </li>
            </ol>
        </nav>
    </div>

    <div class="container-fluid">
        <h1 class="page__title">
            นโยบายการดำเนินงาน
        </h1>
    </div>
</section>

<section>
    <div class="section section--content">
        <div id="policy-container" class="py-5">
            <div class="container-fluid">
                <ul class="nav nav-pills sam-tabs sam-tabs--primary m-0" id="policyTab" role="tablist">
                    <li class="nav-item">
                        <button class="nav-link sam-tabs__link active" data-bs-toggle="tab" data-bs-target="#group1">การบริหารสินทรัพย์ด้อยคุณภาพ บสส.</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link sam-tabs__link" data-bs-toggle="tab" data-bs-target="#group2">การบริหารทรัพย์สินรอการขาย</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link sam-tabs__link" data-bs-toggle="tab" data-bs-target="#group3">การสร้างโอกาสทางธุรกิจ บสส.</button>
                    </li>
                </ul>
                <div class="tab-content accordion--board" id="policyTabContent">
                    <div class="tab-pane fade show active" id="group1">
                        <div class="accordion__header d-md-none"
                             data-bs-toggle="collapse"
                             data-bs-target="#col-group1"
                             aria-expanded="true">
                            <h3 class="accordion__title">
                                การบริหารสินทรัพย์ด้อยคุณภาพ บสส.
                            </h3>
                            <span class="accordion__icon">
                                <i class="bi bi-chevron-down"></i>
                            </span>
                        </div>
                        <div id="col-group1" class="collapse show d-md-block" data-bs-parent="#policyTabContent">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="content-panel ck-content">
                                        <h2>
                                            การบริหารสินทรัพย์ด้อยคุณภาพ บสส.
                                        </h2>
                                        <p>
                                            มีนโยบายมุ่งเน้นให้มีการเจรจาปรับปรุงโครงสร้างหนี้กับลูกหนี้เป็นอันดับแรก โดยคำนึงถึงความ สามารถในการชำระหนี้ของลูกหนี้ รวมถึงร่วมปรึกษาหารือให้ได้ข้อยุติภายใต้แนวทางที่เหมาะสม สำหรับผู้ที่เกี่ยวข้อง เพื่อให้ลูกหนี้ที่มีศักยภาพสามารถดำเนินกิจการต่อไปได้ ทั้งนี้ บสส. อาศัย กระบวนการตามกฎหมายเพียงเท่าที่จำเป็น เพื่อมิให้เกิดความเสียหายแก่องค์กรและภาครัฐโดย รวมเท่านั้น สำหรับลูกหนี้ที่กระจายอยู่ในภูมิภาค บสส. ได้จัดให้มีสำนักงานสาขา 4 สำนักงาน ได้แก่ สาขาเชียงใหม่, ขอนแก่น, สุราษฎร์ธานี และพิษณุโลก เพื่อให้บริการแก่ลูกหนี้โดยทั่วถึง
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="group2">
                        <div class="accordion__header d-md-none"
                             data-bs-toggle="collapse"
                             data-bs-target="#col-group2"
                             aria-expanded="true">
                            <h3 class="accordion__title">
                                การบริหารทรัพย์สินรอการขาย
                            </h3>
                            <span class="accordion__icon">
                                <i class="bi bi-chevron-down"></i>
                            </span>
                        </div>
                        <div id="col-group2" class="collapse show d-md-block" data-bs-parent="#policyTabContent">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="content-panel ck-content">
                                        <h2>
                                            การบริหารทรัพย์สินรอการขาย
                                        </h2>
                                        <p>
                                            ในการบริหารจัดการทรัพย์สินรอการขาย บสส. มีนโยบายที่จะให้มีการนำทรัพย์สินกลับไปใช้ให้เกิด ประโยชน์เพื่อกระตุ้นระบบเศรษฐกิจ และช่วยสร้างมูลค่าเพิ่มให้แก่ทรัพย์สิน ส่งผลให้เกิดการจ้าง งาน สร้างอาชีพให้แก่ประชาชน อันจะนำมาซึ่งความเข้มแข็งทางเศรษฐกิจโดยรวมของประเทศ บสส. จึงทยอยนำทรัพย์สินรอการขายออกจำหน่ายเป็นระยะๆ อย่างต่อเนื่อง รวมถึงเผยแพร่ข้อมูล เพื่อให้เป็นศูนย์รวมอสังหาริมทรัพย์ ที่มีศักยภาพ ในทำเลต่างๆ พร้อมให้ผู้สนใจเลือกลงทุนเพื่อ สร้างโอกาส และความมั่งคั่งทางธุรกิจ โดยผู้สนใจสามารถเข้าดูรายละเอียดผ่านทางเว็บไซต์ ของ บสส. (www.sam.or.th) รวมทั้งอีกหลากหลายช่องทางบนออนไลน์ ทั้ง Line โดยแอด ID Line @@Samline และ Facebook Fanpage : เพจ ทรัพย์มือสองต้อง SAM และ SAM NPA Channel บน YouTube ฯลฯ เพื่อติดตามข้อมูลข่าวสารดีๆ จาก SAM
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="group3">
                        <div class="accordion__header d-md-none"
                             data-bs-toggle="collapse"
                             data-bs-target="#col-group3"
                             aria-expanded="true">
                            <h3 class="accordion__title">
                                การสร้างโอกาสทางธุรกิจ บสส.
                            </h3>
                            <span class="accordion__icon">
                                <i class="bi bi-chevron-down"></i>
                            </span>
                        </div>
                        <div id="col-group3" class="collapse show d-md-block" data-bs-parent="#policyTabContent">
                            <div class="row">
                                <div class="col-lg-8">
                                    <div class="content-panel ck-content">
                                        <h2>
                                            การสร้างโอกาสทางธุรกิจ บสส.
                                        </h2>
                                        <p>
                                            เมื่อปี 2556 บสส. ได้เข้าเป็นสมาชิกใน International Public AMC Forum หรือ IPAF ซึ่งก่อ ตั้งขึ้น ที่ประเทศเกาหลีใต้ ในปี 2555 โดยมีวัตถุประสงค์เพื่อแสวงหาโอกาสทางธุรกิจและความ ร่วมมือระหว่างประเทศ รวมถึงแลกเปลี่ยนเรียนรู้ การฝึกอบรมระหว่างบริษัทบริหารสินทรัพย์ ภาครัฐในประเทศต่างๆ เพื่อป้องกันและเตรียมความพร้อมในการรับมือกับปัญหาทางเศรษฐกิจใน ระดับภูมิภาคเอเชีย นอกจากนี้ บสส. ยังเข้าร่วมกิจกรรมและการอบรมสัมมนาของ IPAF อย่างต่อ เนื่องทุกปี ปัจจุบัน IPAF ประกอบด้วยสมาชิกจากบริษัทบริหารสินทรัพย์ภาครัฐและหน่วยงานอื่นๆ ได้แก่ ประเทศสาธารณรัฐเกาหลี ประเทศสาธารณรัฐประชาชนจีน ประเทศสาธารณรัฐสังคมนิยม เวียดนาม ประเทศสาธารณรัฐคาซัคสถาน ประเทศสหพันธรัฐมาเลเซีย ประเทศฟิลิปปินส์ และ ประเทศไทย
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        #policy-container {
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            background-image: url("/media/images/bg/bg-policy-1.jpg"); /* รูปภาพเริ่มต้น */
            background-attachment: fixed;
        }

        .tab-content {
            margin: 12.5rem 0;
        }

        .content-panel h2 {
            margin-bottom: 1.5rem;
            font-size: clamp(2.5rem, 1.25rem + 5.3vw, 6rem);
            line-height: 1;
            color: #286140;
        }

        .content-panel p {
            font-size: clamp(1rem, 0.89rem + 0.45vw, 1.125rem);
            line-height: 1.4;
        }
    </style>
}
@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const path = window.location.pathname.toLowerCase().replace(/\/$/, ""); // ตัด / ตัวสุดท้ายออกถ้ามี
            const policyContainer = document.getElementById('policy-container');
            const tabLinks = document.querySelectorAll('.sam-tabs__link');

            const backgrounds = {
                '#group1': 'url("/media/images/bg/bg-policy-1.jpg")',
                '#group2': 'url("/media/images/bg/bg-policy-2.jpg")',
                '#group3': 'url("/media/images/bg/bg-policy-3.jpg")'
            };

            const routeMap = {
                '/business-policy/management-non-performing-loans': '#group1',
                '/business-policy/management-non-performing-assets': '#group2',
                '/business-policy/business-opportunities': '#group3'
            };

            function activateTab(targetId) {
                const targetTabButton = document.querySelector(`.sam-tabs__link[data-bs-target="${targetId}"]`);
                if (targetTabButton) {
                    // ใช้ความสามารถของ Bootstrap 5 Tab
                    const tab = new bootstrap.Tab(targetTabButton);
                    tab.show();

                    // อัปเดตพื้นหลังทันทีเมื่อโหลดหน้า (เพราะ shown.bs.tab อาจไม่ทำงานตอนสั่งผ่านโค้ดครั้งแรก)
                    if (backgrounds[targetId] && policyContainer) {
                        policyContainer.style.backgroundImage = backgrounds[targetId];
                    }
                }
            }

            // --- ส่วนที่แก้ไข: ตรวจสอบและรันการ Active Tab ---
            // ค้นหา ID จาก Path ที่เราอยู่
            const initialTabId = routeMap[path];
            if (initialTabId) {
                activateTab(initialTabId);
            }

            // --- ส่วนที่แก้ไข: รวม Logic การคลิกไว้ที่เดียว ---
            tabLinks.forEach(tabBtn => {
                tabBtn.addEventListener('shown.bs.tab', function (event) {
                    const targetId = event.target.getAttribute('data-bs-target');

                    // 1. อัปเดต URL
                    const newPath = Object.keys(routeMap).find(key => routeMap[key] === targetId);
                    if (newPath) {
                        window.history.pushState(null, '', newPath);
                    }

                    // 2. เปลี่ยน Background
                    if (policyContainer && backgrounds[targetId]) {
                        policyContainer.style.backgroundImage = backgrounds[targetId];
                        policyContainer.style.transition = 'background-image 0.5s ease-in-out';
                    }
                });
            });
        });
    </script>
}