@using sam.Models
@model List<AnnualReportViewModel>
@{
    ViewData["Title"] = "หน้าหลัก | บริษัท บริหารสินทรัพย์สุขุมวิท จำกัด";
    ViewData["MetaDescription"] = "บริษัท บริหารสินทรัพย์สุขุมวิท จำกัด";
}

<section class="section section--banner">
    <div class="section__breadcrumb">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">หน้าแรก</a></li>

                <li class="breadcrumb-item dropdown">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        เกี่ยวกับเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">รู้จักเรา</a></li>
                        <li><a class="dropdown-item" href="#">การจัดการองค์กร</a></li>
                        <li><a class="dropdown-item" href="#">นโยบายดำเนินการ</a></li>
                    </ul>
                </li>

                <li class="breadcrumb-item dropdown active" aria-current="page">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        รู้จักเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">วิสัยทัศน์ / พันธกิจ</a></li>
                        <li><a class="dropdown-item" href="#">ประวัติความเป็นมา</a></li>
                    </ul>
                </li>
            </ol>
        </nav>
    </div>

    <div class="container-fluid">
        <h1 class="page__title">
            รายงานประจำปี
        </h1>
    </div>
</section>

<section>
    <div class="section section--content">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div id="annual-container" class="card-deck card-deck--cards-1 card-deck--cards-md-2 card-deck--cards-lg-3">
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center pagination--primary" id="annual-pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        #annual-container {
            transition: opacity 0.4s ease-in-out;
            will-change: opacity;
        }

        /* ใส่ Loading Spinner เล็กๆ ตอนกำลังโหลด (ถ้าต้องการ) */
        .is-loading {
            cursor: wait;
            pointer-events: none;
        }
    </style>
}
@section Scripts {
    <script type="module" src="~/js/features/content/annual-report.js"></script>
    <script>
        $(document).on('click', '.page-link', function (e) {
            e.preventDefault();
            if ($(this).parent().hasClass('disabled') || $(this).parent().hasClass('active')) return;

            const href = $(this).attr('href');
            const segments = href.split('/');
            const page = parseInt(segments[segments.length - 1]);

            // 1. สั่งจางลง (Opacity -> 0)
            $('#annual-container').stop().animate({ opacity: 0 }, 200, function() {

                // 2. เรียกฟังก์ชัน Render ใหม่ (ต้องชื่อเดียวกับที่ผูกในไฟล์ JS)
                if (typeof window.renderContent === 'function') {
                    window.renderContent(page);
                }

                // 3. สั่งแสดงผลกลับมา (Opacity -> 1)
                $(this).animate({ opacity: 1 }, 200);
            });

            // เลื่อนหน้าจอกลับขึ้นไปด้านบน
            $('html, body').stop().animate({
                scrollTop: $("#annual-container").offset().top - 120
            }, 600);

            window.history.pushState({ page: page }, '', href);
        });
    </script>
}