@section Scripts {
    <script>
        function scrollTab(direction) {
            const container = document.querySelector('#execTab');
            const scrollAmount = 200; // ปรับความเร็วในการเลื่อน
            container.scrollLeft += direction * scrollAmount;
        }

        document.addEventListener('DOMContentLoaded', function () {
            const path = window.location.pathname.toLowerCase().replace(/\/$/, ""); // ตัด / ตัวสุดท้ายออกถ้ามี
            const tabLinks = document.querySelectorAll('.sam-tabs__link');

            const routeMap = {
                '/about/vice-president/general-administration': '#group1',
                '/about/vice-president/debt-management': '#group2',
                '/about/vice-president/property-management': '#group3',
                '/about/vice-president/legal-business-support': '#group4',
                '/about/vice-president/finance-and-technology': '#group5',
            };

            function activateTab(targetId) {
                const targetTabButton = document.querySelector(`.sam-tabs__link[data-bs-target="${targetId}"]`);
                if (targetTabButton) {
                    // ใช้ความสามารถของ Bootstrap 5 Tab
                    const tab = new bootstrap.Tab(targetTabButton);
                    tab.show();
                }
            }

            // --- ส่วนที่แก้ไข: ตรวจสอบและรันการ Active Tab ---
            // ค้นหา ID จาก Path ที่เราอยู่
            const initialTabId = routeMap[path];
            if (initialTabId) {
                activateTab(initialTabId);
            }

            // --- ส่วนที่แก้ไข: รวม Logic การคลิกไว้ที่เดียว ---
            tabLinks.forEach(tabBtn => {
                tabBtn.addEventListener('shown.bs.tab', function (event) {
                    const targetId = event.target.getAttribute('data-bs-target');

                    // 1. อัปเดต URL
                    const newPath = Object.keys(routeMap).find(key => routeMap[key] === targetId);
                    if (newPath) {
                        window.history.pushState(null, '', newPath);
                    }
                });
            });
        });
    </script>
}