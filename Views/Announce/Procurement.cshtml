            </div>
            <div class="form form--filter">
                <div class="row">
                    <div class="col-12 col-md-4 col-lg-3 mb-3">
                        <div class="form-group">
                            <div class="search w-100">
                                <input type="text" class="search__input" name="keyword" id="search-keyword" maxlength="100" autocomplete="off" placeholder="ชื่อโครงการ หรือ เลขที่ประกาศ...">
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4 col-lg-3 mb-3">
                        <div class="form-group">
                            <div class="select w-100">
                                <select id="filter-method" class="select__input">
                                    <option value="all">วิธีการจัดซื้อ</option>
                                    <option value="เฉพาะเจาะจง">เฉพาะเจาะจง</option>
                                    <option value="คัดเลือก">คัดเลือก</option>
                                    <option value="e-bidding">e-bidding</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4 col-lg-3 mb-3">
                        <div class="form-group">
                            <div class="select w-100">
                                <select id="filter-type" class="select__input">
                                    <option value="all">ประเภทประกาศ</option>
                                    <option value="ประกาศเชิญชวน">ประกาศเชิญชวน</option>
                                    <option value="ประกาศผู้ชนะ">ประกาศผู้ชนะ</option>
                                    <option value="ยกเลิกประกาศ">ยกเลิกประกาศ</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4 col-lg-3 mb-3">
                        <div class="form-group">
                            <div class="search w-100">
                                <input type="text" id="filter-date-start" class="search__input" placeholder="วันที่เริ่มต้น" required>
                                <div class="search__icon">
                                    <span class="date-icon-wrapper" style="color: #656565">
                                        <svg class="icon"><use xlink:href="#icon-calendar"></use></svg>
                                    </span>
                                </div>
                            </div>
