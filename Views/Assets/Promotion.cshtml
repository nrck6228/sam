@using sam.Models
@model List<PromotionViewModel>
@{
    ViewData["Title"] = "หน้าหลัก | บริษัท บริหารสินทรัพย์สุขุมวิท จำกัด";
    ViewData["MetaDescription"] = "บริษัท บริหารสินทรัพย์สุขุมวิท จำกัด";
}

<section class="section section--banner">
    <div class="section__breadcrumb">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">หน้าแรก</a></li>

                <li class="breadcrumb-item dropdown">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        เกี่ยวกับเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">รู้จักเรา</a></li>
                        <li><a class="dropdown-item" href="#">การจัดการองค์กร</a></li>
                        <li><a class="dropdown-item" href="#">นโยบายดำเนินการ</a></li>
                    </ul>
                </li>

                <li class="breadcrumb-item dropdown active" aria-current="page">
                    <a class="dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        รู้จักเรา
                    </a>
                    <ul class="dropdown-menu">
                        <li><a class="dropdown-item" href="#">วิสัยทัศน์ / พันธกิจ</a></li>
                        <li><a class="dropdown-item" href="#">ประวัติความเป็นมา</a></li>
                    </ul>
                </li>
            </ol>
        </nav>
    </div>

    <div class="container-fluid">
        <h1 class="page__title">
            โปรโมชั่นทรัพย์สินเด่น
        </h1>
    </div>
</section>

<section>
    <div class="section section--content section--promotion">
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div id="promotion-container" class="card-deck card-deck--cards-1 card-deck--cards-md-2 card-deck--cards-lg-3">
                        @foreach (var item in Model)
                        {
                            <div class="card card--promotion">
                                <div class="card__figure">
                                    <img src="@item.ImageUrl" class="card__image" alt="@item.Title">
                                </div>
                                <div class="card__body">
                                    <h5 class="card__title">@item.Title</h5>
                                    <p class="card__text">@item.Description</p>
                                    <time class="card__date">
                                        @item.Date
                                    </time>
                                </div>
                                <a href="@item.Link" class="stretched-link"></a>
                            </div>
                        }
                    </div>

                    <nav aria-label="Page navigation">
                        <ul class="pagination justify-content-center pagination--primary" id="promotion-pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
}
@section Scripts {
    <script type="module" src="~/js/promotion.js"></script>
    <script>
        $(document).on('click', '#promotion-pagination .page-link', function (e) {
            e.preventDefault();

            // ตรวจสอบว่าปุ่มที่คลิกเป็นปุ่มที่ใช้งานได้หรือไม่
            if ($(this).parent().hasClass('disabled') || $(this).parent().hasClass('active')) {
                return;
            }

            const href = $(this).attr('href');
            const segments = href.split('/');
            const page = parseInt(segments[segments.length - 1]);

            if (!page) return;

            // เอฟเฟกต์การเปลี่ยนหน้า
            $('#promotion-container').stop().animate({ opacity: 0 }, 300, function() {
                window.currentPage = page;
                window.renderPromotions(page);
                $(this).animate({ opacity: 1 }, 300);
            });

            // เลื่อนหน้าจอขึ้น
            $('html, body').stop().animate({
                scrollTop: $("#promotion-container").offset().top - 120
            }, 800, 'swing');

            window.history.pushState({ page: page }, '', href);
        });
    </script>
}