@section Styles {
}
@section Scripts {
    <script type="module" src="~/js/features/content/news.js"></script>

    <script>
        $(document).on('click', '#news-pagination .page-link', function (e) {
            e.preventDefault();

            const $btn = $(this);
            const $container = $('#news-container');

            // ป้องกันการกดซ้ำหน้าเดิมหรือปุ่มที่กดไม่ได้
            if ($btn.parent().hasClass('disabled') || $btn.parent().hasClass('active')) return;

            const href = $btn.attr('href');
            const page = parseInt(href.split('/').pop());

            if (isNaN(page)) return;

            // 1. ทำ Animation จางลง
            $container.stop().animate({ opacity: 0 }, 200, function() {

                // 2. เรียกฟังก์ชัน Render ของหน้า News โดยเฉพาะ
                if (typeof window.renderNewsContent === 'function') {
                    window.renderNewsContent(page);
                }

                // 3. ทำ Animation แสดงกลับมา
                $(this).animate({ opacity: 1 }, 200);
            });

            // 4. เลื่อนหน้าจอกลับขึ้นไปที่หัวรายการ
            $('html, body').stop().animate({
                scrollTop: $container.offset().top - 150
            }, 600);

            // 5. อัปเดต URL บน Browser
            window.history.pushState({ page: page }, '', href);
        });
    </script>
}