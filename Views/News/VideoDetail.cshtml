@{
    Layout = "_Layout";
    ViewData["Title"] = "รับชมวิดีโอ";
}

<section class="section section--video-detail py-5 bg-light">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="video-player-main shadow-sm rounded bg-white overflow-hidden">
                    <div class="ratio ratio-16x9">
                        <iframe id="main-video-iframe" src="" frameborder="0" allowfullscreen></iframe>
                    </div>
                    <div class="p-4">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb mb-2">
                                <li class="breadcrumb-item"><a href="/video">วิดีโอ</a></li>
                                <li id="breadcrumb-category" class="breadcrumb-item active">NPA</li>
                            </ol>
                        </nav>
                        <h1 id="video-title" class="h3 fw-bold mb-3 text-primary">กำลังโหลด...</h1>
                        <p id="video-description" class="text-muted"></p>
                        <hr>
                        <div class="d-flex align-items-center justify-content-between">
                            <div class="video-meta">
                                <span id="video-date" class="small text-muted me-3"></span>
                                <span id="video-count-info" class="badge bg-soft-primary text-primary"></span>
                            </div>
                            <div class="video-share">
                                <button class="btn btn-sm btn-outline-secondary rounded-pill">
                                    <i class="bi bi-share me-1"></i> แชร์
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-header bg-white py-3 border-0">
                        <h5 class="mb-0 fw-bold"><i class="bi bi-collection-play me-2"></i>รายการตอนย่อย</h5>
                    </div>
                    <div class="card-body p-0">
                        <div id="playlist-container" class="list-group list-group-flush overflow-auto" style="max-height: 600px;">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Styles {
    <style>
        .bg-soft-primary {
            background-color: rgba(var(--bs-primary-rgb), 0.1);
            color: var(--bs-primary);
        }

        .text-truncate-2 {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .playing-now {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(var(--bs-primary-rgb), 0.7);
            color: white;
            font-size: 0.6rem;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 4px;
        }

        .list-group-item.active h6 {
            color: var(--bs-primary) !important;
        }

        .list-group-item:hover:not(.active) {
            background-color: #f8f9fa;
        }
    </style>
}
@section Scripts {
    <script type="module">
        import { newsData } from '/js/data/data.js';

        document.addEventListener('DOMContentLoaded', () => {
            const currentId = "@ViewBag.Id"; // รับค่าจาก Controller

            // 1. ค้นหาวิดีโอปัจจุบัน
            const currentVideo = newsData.media.find(v => v.id === currentId);
            if (!currentVideo) return;

            // 2. ค้นหาเพื่อนร่วมกลุ่ม (Playlist)
            const playlist = newsData.media.filter(v => v.groupId === currentVideo.groupId);

            // 3. อัปเดต UI หลัก
            document.getElementById('main-video-iframe').src = currentVideo.videoUrl.replace("watch?v=", "embed/") + "?autoplay=1";
            document.getElementById('video-title').textContent = currentVideo.title;
            document.getElementById('video-description').textContent = currentVideo.shortDesc;
            document.getElementById('video-date').innerHTML = `<i class="bi bi-calendar3 me-1"></i> ${currentVideo.displayDate}`;
            document.getElementById('breadcrumb-category').textContent = currentVideo.category;
            document.getElementById('video-count-info').textContent = `${playlist.length} ตอนในชุดนี้`;

            // 4. Render Playlist Sidebar
            const playlistContainer = document.getElementById('playlist-container');
            playlistContainer.innerHTML = playlist.map(item => `
                <a href="/video/${item.id}/${item.slug}"
                   class="list-group-item list-group-item-action border-0 p-3 ${item.id === currentId ? 'active bg-soft-primary' : ''}">
                    <div class="row g-2 align-items-center">
                        <div class="col-4 position-relative">
                            <img src="${item.thumbnail}" class="img-fluid rounded shadow-sm" alt="${item.title}">
                            ${item.id === currentId ? '<div class="playing-now">เล่นอยู่</div>' : ''}
                        </div>
                        <div class="col-8">
                            <h6 class="mb-1 small fw-bold text-truncate-2">${item.title}</h6>
                            <small class="text-muted d-block" style="font-size: 0.7rem;">${item.displayDate}</small>
                        </div>
                    </div>
                </a>
            `).join('');
        });
    </script>
}