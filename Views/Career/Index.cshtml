@section Styles {
    <link href="~/vendors/sweetalert/sweetalert2.min.css" rel="stylesheet" />
}
@section Scripts {
    <script src="~/vendors/sweetalert/sweetalert2.all.min.js"></script>
    <script>
        // --- ส่วนที่ 1: จัด Format เบอร์โทรขณะพิมพ์ (อยู่นอก Event คลิกปุ่ม) ---
        const inputContact = document.getElementById('applyContact');

        inputContact.oninput = function() {
            // 1. ลบตัวอักษรที่ไม่ใช่ตัวเลขออก
            let value = this.value.replace(/\D/g, '');

            // 2. จำกัด 10 หลัก
            if (value.length > 10) value = value.slice(0, 10);

            // 3. จัด Format 0xx-xxx-xxxx
            let formattedValue = '';
            if (value.length > 0) {
                formattedValue = value.substring(0, 3);
                if (value.length > 3) formattedValue += '-' + value.substring(3, 6);
                if (value.length > 6) formattedValue += '-' + value.substring(6, 10);
            }
            this.value = formattedValue;
        };

        // --- ส่วนที่ 2: Logic เมื่อกดปุ่มส่งข้อมูล ---
        document.getElementById('btn-send').addEventListener('click', function() {
            const title = document.getElementById('selectTitle').value;
            const name = document.getElementById('applyName').value;
            const email = document.getElementById('applyEmail').value;
    
            // ดึงค่าเบอร์โทรปัจจุบันแล้วลบขีดออกเพื่อเช็คความยาว
            const rawPhone = document.getElementById('applyContact').value.replace(/-/g, '');

            // 1. ตรวจสอบข้อมูลทั่วไป
            if (name === "" || email === "" || title === "ตำแหน่งที่ต้องการสมัคร") {
                Swal.fire({
                    icon: 'error',
                    title: 'กรุณากรอกข้อมูลให้ครบถ้วน',
                    text: 'ตรวจสอบชื่อ, อีเมล และตำแหน่งงานอีกครั้ง',
                    customClass: {
                        confirmButton: 'btn btn--gray',
                    },
                    buttonsStyling: false,
                    confirmButtonText: 'ตกลง',
                });
                return;
            }

            // 2. ตรวจสอบเบอร์โทร (Validation จริงๆ อยู่ตรงนี้)
            if (rawPhone.length < 10) {
                Swal.fire({
                    icon: 'warning',
                    title: 'เบอร์โทรศัพท์ไม่ถูกต้อง',
                    text: 'กรุณากรอกเบอร์โทรศัพท์ให้ครบ 10 หลัก',
                    customClass: {
                        confirmButton: 'btn btn--gray',
                    },
                    buttonsStyling: false,
                    confirmButtonText: 'ตกลง',
                });
                return;
            }

            // 3. แสดง SweetAlert เมื่อส่งสำเร็จ
            Swal.fire({
                title: 'ส่งข้อมูลสำเร็จ!',
                text: 'เราได้รับข้อมูลการสมัครงานของคุณเรียบร้อยแล้ว',
                icon: 'success',
                customClass: {
                    confirmButton: 'btn btn--green',
                },
                buttonsStyling: false,
                confirmButtonText: 'ตกลง',
            }).then((result) => {
                if (result.isConfirmed) {
                    document.querySelector('.vacancies--form').reset();
                    document.getElementById('custom-text').innerHTML = "No file chosen, yet.";
                }
            });
        });

        document.getElementById('btn-reset-filter').addEventListener('click', function() {
            Swal.fire({
                title: 'คุณต้องการล้างข้อมูลใช่หรือไม่?',
                icon: 'warning',
                showCancelButton: true,
                customClass: {
                        confirmButton: 'btn btn--red',
                        cancelButton: 'btn btn--gray'
                    },
                    buttonsStyling: false,
                    confirmButtonText: 'ตกลง',
                    cancelButtonText: 'ยกเลิก'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.querySelector('.vacancies--form').reset();
                    document.getElementById('custom-text').innerHTML = "No file chosen, yet.";
                }
            });
        });

        const realFileBtn = document.getElementById("real-file");
        const customBtn = document.getElementById("custom-button");
        const customTxt = document.getElementById("custom-text");

        customBtn.addEventListener("click", function() {
            realFileBtn.click();
        });

        realFileBtn.addEventListener("change", function() {
            if (realFileBtn.value) {
                // ตัดเส้นทางไฟล์เพื่อให้เหลือแค่ชื่อไฟล์
                customTxt.innerHTML = realFileBtn.value.match(/[\/\\]([\w\d\s\.\-\(\)]+)$/)[1];
            } else {
                customTxt.innerHTML = "No file chosen, yet.";
            }
        });
    </script>
}